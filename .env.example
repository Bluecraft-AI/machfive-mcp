# MachFive API Configuration
# Copy this file to .env.local and fill in your actual API key

MACHFIVE_API_KEY=mf_live_YOUR_KEY_HERE

# Optional: Override the base URL (defaults to https://app.machfive.io)
# MACHFIVE_BASE_URL=https://app.machfive.io

# Optional: Set transport mode (stdio for local, streamable-http for remote)
# MCP_TRANSPORT=stdio

# Optional: Set logging level
# LOG_LEVEL=INFO
